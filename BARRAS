<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Gráfico de Barras</title>
</head>
<body>

<h2>REALIZADO POR JOSE LUIS SANTOS SEGOVIA</h2>
<canvas id="canvas" width="600" height="400" style="border:4px solid black;"></canvas>

<script>
    var canvas = document.getElementById("canvas");
    var ctx = canvas.getContext("2d");

    // Datos
    var valores = [50, 60, 70, 90, 100];
    var colores = ["red", "blue", "green", "orange", "purple"];

    var anchoBarra = 50;
    var espacio = 25;
    var x = 60;

    for (let i = 0; i < valores.length; i++) {
        let altura = valores[i] * 2; // escala para que se vea grande

        // Dibujar barra
        ctx.fillStyle = colores[i];
        ctx.fillRect(x, canvas.height - altura - 20, anchoBarra, altura);

        // Borde
        ctx.strokeRect(x, canvas.height - altura - 20, anchoBarra, altura);

        // Texto (porcentaje)
        ctx.fillStyle = "red";
        ctx.font = "16px Arial";
        ctx.fillText(valores[i] + "%", x + 5, canvas.height - altura - 25);

        x += anchoBarra + espacio;
    }
</script>

</body>
</html>
